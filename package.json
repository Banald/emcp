{
  "name": "mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --test --import ./tests/setup.ts 'src/**/*.test.ts'",
    "test:coverage": "c8 --config .c8rc.json node --test --import ./tests/setup.ts 'src/**/*.test.ts' 'tests/**/*.test.ts'",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "c8": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "ioredis": "^5.10.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "zod": "^4.3.6"
  }
}
