{
  "name": "mcp-server",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch src/index.ts",
    "dev:worker": "node --env-file=.env --watch src/workers/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/index.js",
    "test": "node --test --import ./tests/setup.ts 'src/**/*.test.ts'",
    "test:coverage": "c8 --config .c8rc.json node --test --import ./tests/setup.ts 'src/**/*.test.ts'",
    "test:integration": "node --test --test-timeout=120000 'tests/integration/**/*.test.ts'",
    "test:all": "npm run test:coverage && npm run test:integration",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/turndown": "^5.0.6",
    "c8": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^10.28.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.26.0",
    "@mozilla/readability": "^0.6.0",
    "croner": "^10.0.1",
    "ioredis": "^5.10.1",
    "linkedom": "^0.18.12",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "prom-client": "^15.1.3",
    "turndown": "^7.2.4",
    "zod": "^4.3.6"
  }
}
