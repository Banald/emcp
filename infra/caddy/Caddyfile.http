# Caddy reverse proxy for eMCP — plain HTTP mode.
#
# Selected by EMCP_PUBLIC_SCHEME=http in .env. TLS is disabled; the site only
# listens on port 80. Use this ONLY on trusted internal networks — bearer
# tokens for /mcp travel in plaintext.
#
# The /health and /metrics edge blocks are identical to Caddyfile.https, so
# the observability endpoints stay unreachable externally regardless of
# scheme.
#
# Configure via .env:
#   EMCP_PUBLIC_HOST — the hostname this server serves on

{
	auto_https off
}

http://{$EMCP_PUBLIC_HOST:localhost} {
	route {
		# Block observability endpoints at the edge. Redundant with the
		# server's loopback-only check in src/server.ts, but surfaces
		# intent and saves a round-trip.
		@internal path /health /metrics /health/* /metrics/*
		respond @internal 404

		# The MCP endpoint is the only thing exposed externally.
		@mcp path /mcp
		reverse_proxy @mcp mcp-server:3000

		# Everything else: 404.
		respond "Not Found" 404
	}
}
