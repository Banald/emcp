# Runtime
NODE_ENV=development
PORT=3000
BIND_HOST=127.0.0.1

# Public-facing identity (used for DNS rebinding defense)
PUBLIC_HOST=localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Postgres
DATABASE_URL=postgres://mcp:mcp@localhost:5432/mcp_dev
DATABASE_POOL_MAX=10

# Redis (rate limiting + cache)
REDIS_URL=redis://localhost:6379

# SearXNG (web search backend, runs in Docker — see infra/searxng/)
SEARXNG_URL=http://localhost:8080

# API key HMAC pepper. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CHANGING THIS INVALIDATES ALL EXISTING API KEYS.
API_KEY_HMAC_SECRET=replace-me-with-32-random-bytes-base64

# Logging
LOG_LEVEL=debug

# Limits and timeouts
RATE_LIMIT_DEFAULT_PER_MINUTE=60
SHUTDOWN_TIMEOUT_MS=30000
