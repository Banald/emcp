# =========================================================================
# Echo configuration
# =========================================================================
# Compose deployment:    cp .env.example .env, edit, then `docker compose up -d`
# Bare-metal deployment: see the "Bare-metal only" block at the bottom
# =========================================================================

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Public-facing identity (DNS rebinding defense) ---
# Hostname Caddy serves on; clients must send this exact value in `Host`.
# Local dev:  'localhost' — Caddy uses its internal CA for self-signed TLS.
# Production: your real domain — Caddy auto-provisions Let's Encrypt certs.
PUBLIC_HOST=localhost

# Comma-separated `Origin` allowlist for the MCP endpoint. Include scheme.
ALLOWED_ORIGINS=http://localhost,https://localhost

# --- Limits ---
DATABASE_POOL_MAX=10
RATE_LIMIT_DEFAULT_PER_MINUTE=60
SHUTDOWN_TIMEOUT_MS=30000

# --- MCP transport tunables (uncomment to override defaults) ---
# MCP_MAX_BODY_BYTES=1048576                # 1 KiB–16 MiB, default 1 MiB
# MCP_SESSION_IDLE_MS=1800000               # 1 min–24 h, default 30 min
# MCP_SESSION_CLEANUP_INTERVAL_MS=60000     # 1 s–10 min, default 1 min
# MCP_TOOL_CALL_TIMEOUT_MS=30000            # 1 s–10 min, default 30 s

# --- Postgres (compose) ---
# The postgres container provisions the database with these credentials.
# The password is loaded from ./secrets/postgres_password.txt (Docker secret).
POSTGRES_USER=mcp
POSTGRES_DB=mcp

# --- SearXNG ---
# Session-cookie secret / bot-limiter salt for SearXNG.
# Generate:  openssl rand -hex 32
# Kept in .env rather than Docker secrets because it is low-sensitivity in
# this deployment (no user sessions, limiter disabled — see
# infra/searxng/settings.yml). Regenerate it in real deployments anyway.
SEARXNG_SECRET=change-me

# --- Caddy / TLS (compose) ---
# PUBLIC_SCHEME selects which Caddyfile the caddy container mounts.
#   https  (default) — Caddy auto-provisions TLS: internal CA for
#                      localhost/IP literals, Let's Encrypt for real
#                      hostnames. Clients connect to https://$PUBLIC_HOST.
#   http              — Plaintext on port 80, TLS disabled. Use ONLY on
#                      trusted internal networks; bearer tokens travel in
#                      the clear. Remember to add the http:// origin to
#                      ALLOWED_ORIGINS above.
PUBLIC_SCHEME=https

# Override if 80/443 are already in use on the host.
# HTTP_PORT=80
# HTTPS_PORT=443

# --- ghcr.io image (compose) ---
# The canonical repo is https://github.com/Banald/echo, so `GHCR_OWNER=banald`
# is already the compose default. Only set it here if you forked the repo.
# Set ECHO_IMAGE_TAG to pin to a released version; otherwise compose builds
# locally on first `up`.
# GHCR_OWNER=banald
# ECHO_IMAGE_TAG=v0.4.0
# ECHO_PULL_POLICY=always

# =========================================================================
# Bare-metal only (not used in compose mode — compose.yaml wires these)
# =========================================================================
# PORT=3000
# BIND_HOST=127.0.0.1
# DATABASE_URL=postgres://mcp:mcp@localhost:5432/mcp_dev
# REDIS_URL=redis://localhost:6379
# SEARXNG_URL=http://localhost:8080
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# API_KEY_HMAC_SECRET=
