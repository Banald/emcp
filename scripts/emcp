#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# emcp — Echo day-2 CLI.
#
# Thin wrapper around `docker compose` in $ECHO_HOME plus passthrough to the
# bundled key-management CLI. Installed by scripts/install.sh.
#
# Run `emcp help` for the full command list.
# ---------------------------------------------------------------------------

set -euo pipefail

EMCP_CONFIG_PATH="${EMCP_CONFIG_PATH:-/etc/echo/config}"

# Env overrides config: allow `ECHO_HOME=/alt/path emcp …` without editing /etc.
if [ -z "${ECHO_HOME:-}" ] && [ -r "$EMCP_CONFIG_PATH" ]; then
    # Config is a simple KEY=VALUE file written by install.sh. Source it in a
    # subshell so we never leak unexpected assignments into the parent shell.
    # shellcheck disable=SC1090
    ECHO_HOME="$(. "$EMCP_CONFIG_PATH" >/dev/null 2>&1; printf '%s' "${ECHO_HOME:-}")"
fi
ECHO_HOME="${ECHO_HOME:-/opt/echo}"

if [ -t 2 ]; then
    C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'
    C_RED=$'\033[1;31m'; C_YELLOW=$'\033[1;33m'
    C_CYAN=$'\033[1;36m'; C_GREEN=$'\033[1;32m'
else
    C_RESET=""; C_BOLD=""; C_RED=""; C_YELLOW=""; C_CYAN=""; C_GREEN=""
fi

log_error() { printf '%s[emcp]%s %s\n' "$C_RED"    "$C_RESET" "$*" >&2; }
log_warn()  { printf '%s[emcp]%s %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
log_info()  { printf '%s[emcp]%s %s\n' "$C_CYAN"   "$C_RESET" "$*" >&2; }

die() { log_error "$*"; exit 1; }

require_home() {
    [ -f "$ECHO_HOME/compose.yaml" ] \
        || die "no compose.yaml at $ECHO_HOME. Run install.sh or set ECHO_HOME."
}

dc() {
    require_home
    ( cd "$ECHO_HOME" && docker compose "$@" )
}

usage() {
    cat <<EOF
${C_BOLD}emcp${C_RESET} — Echo day-2 CLI

${C_BOLD}USAGE${C_RESET}
    emcp <command> [args...]

${C_BOLD}LIFECYCLE${C_RESET}
    up              start the stack (docker compose up -d)
    down [-v]       stop the stack; -v also wipes volumes (destructive)
    restart [svc…]  restart all services, or named ones
    status, ps      docker compose ps
    version         installer + image tag currently running

${C_BOLD}OBSERVABILITY${C_RESET}
    logs [svc…]     tail logs (follow, last 100 lines)
    log             alias for 'logs'
    health          one-shot health probe via the mcp-server container

${C_BOLD}DATA${C_RESET}
    migrate [cmd] [n]   run migrations. cmd defaults to 'up'.
                        examples: emcp migrate up  |  emcp migrate status
                                  emcp migrate down 1

${C_BOLD}API KEYS${C_RESET}
    key create --name "..." [--rate-limit N] [--allow-no-origin]
    key list [--status active|blacklisted|deleted|all]
    key show <id-or-prefix>
    key blacklist <id-or-prefix> [--reason "..."] [--yes]
    key unblacklist <id-or-prefix> [--yes]
    key delete <id-or-prefix> [--yes]
    key set-rate-limit <id-or-prefix> <per-minute>

${C_BOLD}MAINTENANCE${C_RESET}
    update [tag]    pull the image (new tag if given), restart
    config          re-run the env wizard against this install
    uninstall       stop the stack, remove everything (destroys data)

${C_BOLD}CONFIG${C_RESET}
    \$ECHO_HOME      ${ECHO_HOME}
    \$EMCP_CONFIG_PATH ${EMCP_CONFIG_PATH}

EOF
}

cmd_up()      { dc up -d "$@"; }
cmd_down()    { dc down "$@"; }
cmd_restart() { dc restart "$@"; }
cmd_status()  { dc ps "$@"; }
cmd_logs()    { dc logs -f --tail 100 "$@"; }

cmd_health() {
    require_home
    ( cd "$ECHO_HOME" && docker compose exec -T mcp-server \
        node -e "fetch('http://127.0.0.1:3000/health').then(r=>r.text()).then(t=>{console.log(t);process.exit(r.ok?0:1)})" 2>&1 )
}

cmd_migrate() {
    local sub="${1:-up}"
    shift || true
    require_home
    ( cd "$ECHO_HOME" && docker compose run --rm migrate \
        node dist/db/migrate.js "$sub" "$@" )
}

cmd_key() {
    require_home
    ( cd "$ECHO_HOME" && docker compose run --rm mcp-server \
        node dist/cli/keys.js "$@" )
}

cmd_update() {
    require_home
    local new_tag="${1:-}"
    if [ -n "$new_tag" ]; then
        local stripped="${new_tag#v}"
        log_info "pinning ECHO_IMAGE_TAG=${stripped} in ${ECHO_HOME}/.env"
        if grep -q '^ECHO_IMAGE_TAG=' "$ECHO_HOME/.env"; then
            sed -i "s|^ECHO_IMAGE_TAG=.*|ECHO_IMAGE_TAG=${stripped}|" "$ECHO_HOME/.env"
        else
            printf 'ECHO_IMAGE_TAG=%s\n' "$stripped" >> "$ECHO_HOME/.env"
        fi
    fi
    ( cd "$ECHO_HOME" && docker compose pull && docker compose up -d )
}

cmd_config() {
    require_home
    local installer="$ECHO_HOME/bin/install.sh"
    [ -x "$installer" ] || die "installer not found at $installer — run install.sh manually"
    if [ "$(id -u)" -ne 0 ]; then
        exec sudo -E "$installer" --reconfigure --install-dir "$ECHO_HOME"
    fi
    exec "$installer" --reconfigure --install-dir "$ECHO_HOME"
}

cmd_uninstall() {
    local installer="$ECHO_HOME/bin/install.sh"
    [ -x "$installer" ] || die "installer not found at $installer — run install.sh --uninstall manually"
    if [ "$(id -u)" -ne 0 ]; then
        exec sudo -E "$installer" --uninstall --install-dir "$ECHO_HOME" "$@"
    fi
    exec "$installer" --uninstall --install-dir "$ECHO_HOME" "$@"
}

cmd_version() {
    local installer="$ECHO_HOME/bin/install.sh"
    local inst_ver="unknown"
    if [ -f "$installer" ]; then
        inst_ver="$(awk -F'"' '/^ECHO_INSTALLER_VERSION=/ {print $2; exit}' "$installer")"
    fi
    local img_tag=""
    if [ -f "$ECHO_HOME/.env" ]; then
        img_tag="$(awk -F= '/^ECHO_IMAGE_TAG=/ {print $2; exit}' "$ECHO_HOME/.env")"
    fi
    printf 'emcp\n  installer: %s\n  image tag: %s\n  compose dir: %s\n' \
        "$inst_ver" "${img_tag:-<unset>}" "$ECHO_HOME"
}

main() {
    local cmd="${1:-help}"
    shift || true
    case "$cmd" in
        up)           cmd_up "$@" ;;
        down)         cmd_down "$@" ;;
        restart)      cmd_restart "$@" ;;
        status|ps)    cmd_status "$@" ;;
        logs|log)     cmd_logs "$@" ;;
        health)       cmd_health "$@" ;;
        migrate)      cmd_migrate "$@" ;;
        key)          cmd_key "$@" ;;
        update|upgrade) cmd_update "$@" ;;
        config)       cmd_config "$@" ;;
        uninstall)    cmd_uninstall "$@" ;;
        version|--version|-V) cmd_version ;;
        help|--help|-h|"") usage ;;
        *)
            log_error "unknown command: $cmd"
            usage
            exit 2
            ;;
    esac
}

main "$@"
